# Environment Variables Template
# Copy this file to .env and fill in your values

# MongoDB Connection (use MongoDB Atlas connection string)
# Format: mongodb+srv://<DB_USERNAME>:<DB_PASSWORD>@cluster.mongodb.net/database?retryWrites=true&w=majority
# Get this from MongoDB Atlas:
#   1. Go to MongoDB Atlas Dashboard
#   2. Click "Connect" on your cluster
#   3. Choose "Drivers" (not X.509)
#   4. Select Node.js
#   5. Copy the connection string and replace username/password
MONGODB_URI=mongodb+srv://<DB_USERNAME>:<DB_PASSWORD>@cluster.mongodb.net/blog?retryWrites=true&w=majority

# Optional: override MongoDB collection name (default: articles)
MONGODB_COLLECTION=articles

# Node Environment
NODE_ENV=development

# Server Port (internal Node.js port - Nginx proxies 80/443 to this)
# Users access via standard web ports, Nginx reverse-proxies to this port
PORT=5000

# Session Secret (generate a random string, change this for production!)
# Generate one with: openssl rand -base64 32
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Email Configuration (contact form — via Resend)
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key
EMAIL_TO=your-email@gmail.com

# ElevenLabs Conversational AI (Italian voice tutor)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id

# OpenAI (for DALL-E 3 vocab image generation)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-openai-api-key...

# CDN base URL for pre-generated vocabulary images
# Leave empty to serve from local /public/img/vocab/ (development)
# Set to your CDN domain for production, e.g. https://cdn.example.com
CDN_BASE=
