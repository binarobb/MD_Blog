<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/style.css">
    <title>Italian &mdash; Intentional Owl</title>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><img src="/owl3.png" alt="Intentional Owl"></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/blog">Blog</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/italian">Italian</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/contact">Contact</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="page-shell">
        <div class="hero">
            <h1 class="mb-2">&#x1F1EE;&#x1F1F9; Italian</h1>
            <h3 class="text-muted">Language learning, one lesson at a time.</h3>
            <p class="lead">An interactive app for building Italian vocabulary, grammar, and reading comprehension.</p>
            <a href="/" class="btn btn-outline-light mt-2">&larr; Back to Home</a>
        </div>

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 section-title">
            <h2 class="mb-0">What&rsquo;s Coming</h2>
        </div>
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="content-card h-100">
                    <div class="card-body">
                        <h4 class="card-title">Vocabulary</h4>
                        <p class="card-text text-muted">Flashcard-style vocabulary practice with spaced repetition to build lasting recall.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="content-card h-100">
                    <div class="card-body">
                        <h4 class="card-title">Grammar</h4>
                        <p class="card-text text-muted">Interactive exercises covering verb conjugation, noun gender, and sentence structure.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="content-card h-100">
                    <div class="card-body">
                        <h4 class="card-title">Reading Practice</h4>
                        <p class="card-text text-muted">Read and translate real Italian sentences and short passages at every level.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="bg-dark text-white text-center py-3 mt-5">
        <p>&copy; <span id="year"></span> Intentional Owl. All rights reserved.</p>
    </footer>
    <script>
        document.getElementById('year').textContent = new Date().getFullYear();
