    <!-- ElevenLabs Conversational AI client (ESM via CDN) -->
    <script type="module">
      import { Conversation } from 'https://esm.sh/@elevenlabs/client@1';

      const btn = document.getElementById('gufo-btn');
      const icon = document.getElementById('gufo-icon');
      const waves = document.getElementById('gufo-waves');
      const label = document.getElementById('gufo-label');
      const statusEl = document.getElementById('gufo-status');
      const container = document.getElementById('gufo-container');

      let conversation = null;
      let state = 'idle'; // idle | connecting | connected

      function setState(s, detail) {
        state = s;
        container.setAttribute('data-state', s);
        switch (s) {
          case 'idle':
            waves.className = 'gufo-waves-hidden';
            label.textContent = 'Gufo';
            statusEl.classList.add('d-none');
            break;
          case 'connecting':
            waves.className = 'gufo-waves-hidden';
            label.textContent = 'Connecting…';
            statusEl.classList.add('d-none');
            break;
          case 'connected':
            label.textContent = 'Gufo';
            statusEl.classList.remove('d-none');
            statusEl.textContent = detail || 'Listening…';
            break;
        }
      }

      btn.addEventListener('click', async () => {
        if (state === 'connecting') return;

        if (state === 'connected' && conversation) {
          await conversation.endSession();
          conversation = null;
          setState('idle');
          return;
        }

        setState('connecting');
        try {
          await navigator.mediaDevices.getUserMedia({ audio: true });

          conversation = await Conversation.startSession({
            agentId: 'agent_6101kmvat5gqfvmvk91erw2bra5z',
            onConnect: ({ conversationId }) => {
              console.log('Gufo connected, id:', conversationId);
              setState('connected', 'Listening…');
            },
            onDisconnect: () => {
              console.log('Gufo disconnected');
              conversation = null;
              setState('idle');
            },
            onError: (err) => {
              console.error('Gufo error:', err);
              conversation = null;
              setState('idle');
            },
            onMessage: (message) => {
              console.log('Gufo message:', message);
            },
            onModeChange: (mode) => {
              console.log('Gufo mode:', mode);
              if (state !== 'connected') return;
              if (mode.mode === 'speaking') {
                waves.className = 'gufo-waves-active';
                statusEl.textContent = 'Speaking…';
              } else {
                waves.className = 'gufo-waves-listening';
                statusEl.textContent = 'Listening…';
              }
            },
          });
        } catch (err) {
          console.error('Failed to start Gufo:', err);
          setState('idle');
        }
      });
    </script>
