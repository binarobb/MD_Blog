<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/style.css">
    <title>Intentional Owl — Portfolio</title>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><img src="/owl3.png" alt="Intentional Owl"></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/blog">Blog</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/italian">Italian</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/contact">Contact</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <% if (isAdmin) { %>
                        <li class="nav-item">
                            <form action="/logout" method="POST" class="d-inline">
                                <button type="submit" class="btn btn-link nav-link">Logout</button>
                            </form>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/login">Login</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="page-shell">

        <!-- Hero -->
        <div class="hero">
            <h1 class="mb-2">Intentional Owl</h1>
            <h3 class="text-muted">What does an owl do to be intentional?</h3>
            <p class="lead">Building software, learning languages, and writing it all down.</p>
            <div class="mt-3 d-flex gap-2 justify-content-center flex-wrap">
                <a href="/about" class="btn btn-outline-light">About Me</a>
                <a href="/contact" class="btn btn-primary">Get in Touch</a>
            </div>
        </div>

        <!-- Projects -->
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 section-title">
            <h2 class="mb-0">Projects</h2>
        </div>
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="content-card h-100">
                    <div class="card-body d-flex flex-column">
                        <h3 class="card-title">&#x1F4DD; Blog</h3>
                        <p class="card-text flex-grow-1">Thoughtful engineering, practical learning, and consistent growth. Notes from the day-to-day of building things.</p>
                        <a href="/blog" class="btn btn-primary mt-3">Read the Blog</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="content-card h-100">
                    <div class="card-body d-flex flex-column">
                        <h3 class="card-title">&#x1F1EE;&#x1F1F9; Italian</h3>
                        <p class="card-text flex-grow-1">An interactive app for learning Italian — vocabulary, grammar, and practice exercises all in one place.</p>
                        <a href="/italian" class="btn btn-primary mt-3">Launch App</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Roadmap -->
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 section-title">
            <h2 class="mb-0">Roadmap</h2>
        </div>
        <div class="roadmap mb-4">

            <div class="roadmap-item roadmap-done">
                <div class="roadmap-icon">✓</div>
                <div class="roadmap-body">
                    <div class="roadmap-title">Italian A1 Learning App</div>
                    <div class="roadmap-desc">Vocabulary, verb drill, grammar quiz, and sentence builder backed by MongoDB.</div>
                </div>
            </div>

            <div class="roadmap-item roadmap-done">
                <div class="roadmap-icon">✓</div>
                <div class="roadmap-body">
                    <div class="roadmap-title">A2 / B1 Expansion — Reading &amp; Idioms</div>
                    <div class="roadmap-desc">86 verbs across three levels, reading comprehension passages, idiom expression study, and tabbed conjugation modal.</div>
                </div>
            </div>

            <div class="roadmap-item roadmap-done">
                <div class="roadmap-icon">✓</div>
                <div class="roadmap-body">
                    <div class="roadmap-title">Gufo Voice Tutor</div>
                    <div class="roadmap-desc">Live voice conversation practice powered by ElevenLabs Conversational AI.</div>
                </div>
            </div>

            <div class="roadmap-item roadmap-next">
                <div class="roadmap-icon">→</div>
                <div class="roadmap-body">
                    <div class="roadmap-title">B2 Content &amp; Writing Exercises</div>
                    <div class="roadmap-desc">Expand verb library and passages to B2, add free-write prompts with basic grammar feedback.</div>
                </div>
            </div>

            <div class="roadmap-item roadmap-planned">
                <div class="roadmap-icon">◦</div>
                <div class="roadmap-body">
                    <div class="roadmap-title">Spaced Repetition Review Mode</div>
                    <div class="roadmap-desc">SM-2 flashcard scheduler for vocabulary and verbs, tracking per-card performance in MongoDB.</div>
                </div>
            </div>

            <div class="roadmap-item roadmap-planned">
                <div class="roadmap-icon">◦</div>
                <div class="roadmap-body">
                    <div class="roadmap-title">Progress Dashboard</div>
                    <div class="roadmap-desc">Persistent per-user stats — streaks, accuracy trends, and level progression across all sections.</div>
                </div>
            </div>

        </div>

        <!-- Latest from the Blog -->
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 section-title">
            <h2 class="mb-0">Latest from the Blog</h2>
            <a href="/blog" class="btn btn-outline-secondary btn-sm">All posts &rarr;</a>
        </div>

        <% if (recentArticles.length > 0) { %>
            <% recentArticles.forEach(article => { %>
                <div class="content-card mt-3">
                    <% if (article.featuredImage) { %>
                        <img src="<%= article.featuredImage %>" class="card-img-top" alt="<%= article.title %>" onerror="this.style.display='none'">
                    <% } %>
                    <div class="card-body">
                        <h3 class="card-title"><%= article.title %></h3>
                        <div class="meta-row">
                            <%= article.createdAt.toLocaleDateString() %> by <%= article.author %>
                            <% if (article.readingTime) { %> | <%= article.readingTime %> min read <% } %>
                        </div>
                        <% if (article.category) { %>
                            <a href="/blog/categories/<%= encodeURIComponent(article.category) %>" class="chip chip-category"><%= article.category %></a>
                        <% } %>
                        <% if (article.tags && article.tags.length > 0) { %>
                            <% article.tags.forEach(tag => { %>
                                <a href="/blog/tags/<%= encodeURIComponent(tag) %>" class="chip chip-tag" data-tag="<%= tag %>"><%= tag %></a>
                            <% }) %>
                        <% } %>
                        <div class="card-text mb-2"><%= article.description %></div>
                        <a href="/blog/<%= article.slug %>" class="btn btn-primary">Read More</a>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <p class="text-muted mt-3">No posts yet — check back soon.</p>
        <% } %>

    </div>

    <footer class="bg-dark text-white text-center py-3 mt-5">
        <p>&copy; <span id="year"></span> Intentional Owl. All rights reserved.</p>
    </footer>
    <script>
        document.getElementById('year').textContent = new Date().getFullYear();
    </script>
    <script src="/script.js"></script>
</body>
</html>
